# Home Assistant connection — copy to .env and fill in your values
#
# IMPORTANT: Do NOT use inline comments on value lines below.
# Makefile's 'include' treats everything after '=' as the value, including # comments.
# Use only full-line comments (lines starting with #).

# SSH hostname, IP address, or SSH config alias (e.g. 192.168.1.100 or "ha")
HA_HOST=homeassistant.local

# Your HA URL — include port if non-standard
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token — generate at: HA → Profile → Security → Long-Lived Access Tokens
HA_TOKEN=your_long_lived_token

# SSH add-on user (usually root)
SSH_USER=root

# Remote config directory on HA instance
# HA OS with SSH add-on: /homeassistant/
# HA Container/Supervised: /config/
# Tip: run 'ssh YOUR_HOST "ls /homeassistant/configuration.yaml /config/configuration.yaml 2>&1"' to check
HA_REMOTE_PATH=/config/

# go2rtc URL for camera streams — leave empty or remove if not using cameras
# VITE_GO2RTC_URL=http://homeassistant.local:1984
